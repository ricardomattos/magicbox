FROM node:20-alpine AS builder
WORKDIR /app
ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL
COPY package.json .
RUN npm install
COPY . .
RUN npm run build

# The dist folder is consumed by the nginx service via Docker volume
FROM alpine:latest
COPY --from=builder /app/dist /app/dist
VOLUME /app/dist
CMD ["sh", "-c", "cp -r /app/dist/. /output/ && echo 'Frontend build copied'"]
